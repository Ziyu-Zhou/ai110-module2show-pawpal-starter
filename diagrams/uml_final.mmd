classDiagram
    class Owner {
        +String name
        +String preferences
        +List~Pet~ pets
        +add_pet(pet) void
        +get_all_tasks() List~Task~
    }

    class Pet {
        +String name
        +String species
        +List~Task~ tasks
        +add_task(task) void
        +edit_task(index, task) void
    }

    class Task {
        +String description
        +int duration_minutes
        +String frequency
        +String priority
        +bool completed
        +Date due_date
        +String start_time
        +mark_complete() Optional~Task~
    }

    class Scheduler {
        +int available_minutes
        +String start_time
        +List~Task~ scheduled_tasks
        +List~Task~ skipped_tasks
        +List~String~ explanations
        +Map~Task, String~ scheduled_start_times
        +List~String~ conflict_warnings
        +sort_by_time(tasks, shortest_first) List~Task~
        +filter_tasks(owner, completed, pet_name) List~Task~
        +complete_task(pet, task) Optional~Task~
        +detect_conflicts(owner) List~String~
        +generate_schedule(owner) List~Task~
        +explain_schedule() List~String~
        +format_daily_plan(owner) String
        -_matches_preference(task, preferences) bool
        -_find_pet_for_task(owner, task) Optional~Pet~
    }

    Owner "1" o-- "0..*" Pet : owns
    Pet "1" o-- "0..*" Task : manages
    Owner ..> Task : retrieves
    Scheduler ..> Owner : reads tasks and preferences
    Scheduler ..> Pet : completes and finds tasks
    Scheduler --> "0..*" Task : schedules and skips
    Task ..> Task : creates next recurrence
